# Backend / Docker
MYSQL_HOST=db
MYSQL_PORT=3306
MYSQL_USER=assess
MYSQL_PASSWORD=change_me_strong
MYSQL_DATABASE=handwritten_assessment

DATABASE_URL=mysql+pymysql://assess:change_me_strong@db:3306/handwritten_assessment

SECRET_KEY=generate-a-long-random-string-for-jwt
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# OCR
TESSERACT_CMD=/usr/bin/tesseract
DEFAULT_OCR_LANG=eng

# NLP (Sentence-BERT)
SBERT_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# Scoring weights (sum need not be 1; normalized internally)
WEIGHT_SEMANTIC=0.65
WEIGHT_KEYWORD=0.35

# CORS (comma-separated origins for browser)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional: EasyOCR (set USE_EASYOCR=true and install easyocr in image)
USE_EASYOCR=false
